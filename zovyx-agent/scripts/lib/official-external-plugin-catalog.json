{
  "entries": [
    {
      "name": "@zuvix/acpx",
      "description": "Zuvix ACP runtime backend",
      "source": "official",
      "kind": "plugin",
      "zuvix": {
        "plugin": {
          "id": "acpx",
          "label": "ACPX Runtime"
        },
        "install": {
          "npmSpec": "@zuvix/acpx",
          "defaultChoice": "npm",
          "minHostVersion": ">=2026.4.25"
        }
      }
    },
    {
      "name": "@zuvix/brave-plugin",
      "description": "Zuvix Brave plugin",
      "source": "official",
      "kind": "plugin",
      "zuvix": {
        "plugin": {
          "id": "brave",
          "label": "Brave"
        },
        "webSearchProviders": [
          {
            "id": "brave",
            "label": "Brave Search",
            "hint": "Brave Search web results.",
            "onboardingScopes": ["text-inference"],
            "credentialLabel": "Brave Search API key",
            "envVars": ["BRAVE_API_KEY"],
            "placeholder": "BSA...",
            "signupUrl": "https://api-dashboard.search.brave.com/app/keys",
            "docsUrl": "https://docs.zuvix.ai/tools/brave-search",
            "credentialPath": "plugins.entries.brave.config.webSearch.apiKey",
            "autoDetectOrder": 10
          }
        ],
        "install": {
          "npmSpec": "@zuvix/brave-plugin",
          "defaultChoice": "npm",
          "minHostVersion": ">=2026.4.10",
          "allowInvalidConfigRecovery": true
        }
      }
    },
