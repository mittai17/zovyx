{
  "name": "@zuvix/google-meet",
  "version": "2026.6.2",
  "description": "Zuvix Google Meet participant plugin for joining calls through Chrome or Twilio transports.",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuvix/zuvix"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@zuvix/plugin-sdk": "workspace:*",
    "zuvix": "npm:zuvix@2026.5.28"
  },
  "peerDependencies": {
    "zuvix": ">=2026.6.2"
  },
  "peerDependenciesMeta": {
    "zuvix": {
      "optional": true
    }
  },
  "zuvix": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@zuvix/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "zuvixVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
