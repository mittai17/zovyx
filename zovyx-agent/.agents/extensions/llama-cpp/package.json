{
  "name": "@zuvix/llama-cpp-provider",
  "version": "2026.6.2",
  "description": "Zuvix llama.cpp embedding provider plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuvix/zuvix"
  },
  "type": "module",
  "dependencies": {
    "node-llama-cpp": "3.18.1"
  },
  "devDependencies": {
    "@zuvix/plugin-sdk": "workspace:*"
  },
  "zuvix": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@zuvix/llama-cpp-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.2"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "zuvixVersion": "2026.6.2"
    },
    "release": {
      "bundleRuntimeDependencies": false,
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
